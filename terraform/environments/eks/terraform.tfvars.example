# Copy to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit it.

kubectl_context = "arn:aws:eks:<region>:<account-id>:cluster/<cluster-name>"

minio_root_user     = "changeme-minio-user"
minio_root_password = "changeme-strong-password"
postgres_password   = "changeme-pg-password"
mlflow_secret_key   = "changeme-32-char-random-secret!!"
